        ],
        "summary": "Get current logged in user data",
        "responses": {
          "200": {
            "description": "Get profile success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 200
                    },
                    "status": {
                      "type": "string",
                      "default": "Ok"
                    },
                    "data": {
                      "$ref": "#/components/schemas/User"
                    },
                    "errors": {
                      "default": null
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/schemas/ResponseUnauthorized"
          },
          "429": {
            "$ref": "#/components/schemas/ResponseTooManyRequest"
          }
        }
      },
      "put": {
        "tags": [
          "Profile"
        ],
        "summary": "Change user identity"
      }
    },
    "/profile/photo": {
