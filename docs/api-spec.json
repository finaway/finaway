                      "type": "string",
                      "default": "BadRequest"
                    },
                    "data": {
                      "default": null
                    },
                    "errors": {
                      "type": "object",
                      "properties": {
                        "refresh_token": {
                          "$ref": "#/components/schemas/ValidationError"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/schemas/ResponseTooManyRequest"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Authorization"
        ],
        "summary": "Generate new access token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
