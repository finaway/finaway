                    },
                    "status": {
                      "type": "string",
                      "default": "Ok"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "access_token": {
                          "type": "string",
                          "example": "eyXxx.eyXxx.xxx"
