{
  "openapi": "3.0.2",
  "info": {
    "title": "API Finaway",
    "description": "API Spec for Finaway RESTful API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://finaway.id/api/v1"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Check credentials and get auth token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "uniqueItems": true,
                    "example": "johndoe@mail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "secret"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged in success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 201
                    },
                    "status": {
                      "type": "string",
                      "default": "Created"
                    },
                    "data": {
                      "$ref": "#/components/schemas/DataAuthenticationSuccess"
                    },
                    "errors": {
                      "default": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 400
                    },
                    "status": {
                      "type": "string",
                      "default": "BadRequest"
                    },
                    "data": {
                      "default": null
                    },
                    "errors": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "$ref": "#/components/schemas/ValidationError"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/schemas/ResponseTooManyRequest"
          }
        }
      }
    },
    "/auth/signup": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Register new account",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signup success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 201
                    },
                    "status": {
                      "type": "string",
                      "default": "Created"
                    },
                    "data": {
                      "$ref": "#/components/schemas/DataAuthenticationSuccess"
                    },
                    "errors": {
                      "default": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 400
                    },
                    "status": {
                      "type": "string",
                      "default": "BadRequest"
                    },
                    "errors": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "$ref": "#/components/schemas/ValidationError"
                        },
                        "email": {
                          "$ref": "#/components/schemas/ValidationError"
                        },
                        "password": {
                          "$ref": "#/components/schemas/ValidationError"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/schemas/ResponseTooManyRequest"
          }
        }
      }
    },
    "/auth/activate/{token}": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Account activation",
        "parameters": [
          {
            "in": "path",
            "name": "token",
            "description": "Account activation token that have been sent by email",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Account activation success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 200
                    },
                    "status": {
                      "type": "string",
                      "default": "Ok"
                    },
                    "data": {
                      "default": null
                    },
                    "errors": {
                      "default": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 400
                    },
                    "status": {
                      "type": "string",
                      "default": "BadRequest"
                    },
                    "data": {
                      "default": null
                    },
                    "errors": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "$ref": "#/components/schemas/ValidationError"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/schemas/ResponseTooManyRequest"
          }
        }
      }
    },
    "/auth/password/reset": {
