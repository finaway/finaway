    "/auth/password/reset/{token}": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Get user's name & email by reset password token",
        "parameters": [
          {
            "in": "path",
            "name": "token",
            "description": "Forgot password token that have been sent by email",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Get user data success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 200
                    },
                    "status": {
                      "type": "string",
                      "default": "Ok"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string",
                          "example": "John Doe"
                        },
                        "email": {
                          "type": "string",
                          "example": "johndoe@mail.com"
                        }
                      }
                    },
                    "errors": {
                      "default": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 400
                    },
                    "status": {
                      "type": "string",
                      "default": "BadRequest"
                    },
                    "data": {
                      "default": null
                    },
                    "errors": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "$ref": "#/components/schemas/ValidationError"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/schemas/ResponseTooManyRequest"
          }
        }
      },
      "put": {
        "tags": [
          "Authentication"
        ],
        "summary": "Reset current password with new password",
        "parameters": [
          {
            "in": "path",
            "name": "token",
            "description": "Forgot password token that have been sent by email",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "password"
                ],
                "properties": {
                  "password": {
                    "description": "New password",
                    "type": "string",
                    "example": "secret"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 200
                    },
                    "status": {
                      "type": "string",
                      "default": "Ok"
                    },
                    "data": {
                      "default": null
                    },
                    "errors": {
                      "default": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 400
                    },
                    "status": {
                      "type": "string",
                      "default": "BadRequest"
                    },
                    "data": {
                      "default": null
                    },
                    "errors": {
                      "type": "object",
                      "properties": {
