        },
        "responses": {
          "200": {
            "description": "Reset password request success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "number",
                      "default": 200
                    },
                    "status": {
                      "type": "string",
                      "default": "Ok"
                    },
                    "data": {
                      "default": null
                    },
                    "errors": {
                      "default": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
