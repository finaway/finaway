  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "required": [
          "id",
          "name",
          "email",
          "password",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true,
            "example": "07885962-b316-4fa9-9d9a-018e94020fd1"
          },
          "name": {
            "type": "string",
            "minLength": 0,
            "maxLength": 50,
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "uniqueItems": true,
            "minLength": 0,
            "maxLength": 255,
            "example": "johndoe@mail.com"
          },
          "password": {
            "type": "string",
            "writeOnly": true
          },
          "is_verified": {
            "type": "boolean",
            "readOnly": true,
            "example": true
          },
          "created_at": {
            "type": "number",
            "readOnly": true,
            "example": 1351700038
          },
          "updated_at": {
            "type": "number",
            "readOnly": true,
            "nullable": true,
            "example": 1351700038
          }
        }
      },
      "DataAuthenticationSuccess": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "eyXxx.eyXxx.xxx"
          },
          "refresh_token": {
            "type": "string",
            "example": "eyXxx.eyXxx.xxx"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "ResponseUnauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "number",
                  "default": 401
                },
                "status": {
                  "type": "string",
                  "default": "Unauthorized"
                },
                "data": {
                  "type": "object",
                  "nullable": true,
                  "default": null
                },
                "errors": {
                  "type": "object",
                  "properties": {
                    "_global": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "default": "Unauthorized"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ResponseTooManyRequest": {
        "description": "Too many request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "number",
                  "default": 429
                },
                "status": {
                  "type": "string",
                  "default": "TooManyRequest"
                },
                "data": {
                  "type": "object",
                  "nullable": true,
                  "default": null
                },
                "errors": {
                  "type": "object",
                  "properties": {
                    "_global": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "default": "Too many request"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}